# 15 Signals · 环境变量模板
# 用法：cp .env.example .env，然后填入真实值

# ----- 数据库 -----
# 本地 Postgres:   postgres://postgres:postgres@localhost:5432/signals
# Supabase:        见 Supabase 项目 → Settings → Database → Connection string
DATABASE_URL=postgres://user:password@host:5432/dbname

# ----- Voyage AI (嵌入) -----
# 申请：https://www.voyageai.com/
VOYAGE_API_KEY=pa-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VOYAGE_MODEL=voyage-3   # 1024 维，与 schema.sql 中的 vector(1024) 对齐

# ----- DeepSeek (主对话 + 信号评分) -----
# 申请：https://platform.deepseek.com/
# API 协议：OpenAI 兼容，base_url = https://api.deepseek.com
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL_MENTOR=deepseek-chat       # V3，主对话
DEEPSEEK_MODEL_SCORER=deepseek-chat       # 信号评分

# ----- Langfuse (可观测性，可选) -----
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# LANGFUSE_HOST=https://cloud.langfuse.com
